@startuml

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Helvetica
skinparam dpi 200
skinparam padding 2

skinparam actor {
    BackgroundColor white
    BorderColor #333333
    FontSize 12
}

skinparam usecase {
    BackgroundColor #EEEEEE
    BorderColor #444444
    FontSize 11
}

skinparam rectangle {
    BackgroundColor #FAFAFA
    BorderColor #333333
    FontSize 15
    RoundCorner 12
    FontStyle bold
}

skinparam database {
    BackgroundColor #F0F0F0
    BorderColor #555555
    FontSize 10
}

skinparam cloud {
    BackgroundColor #F0F0F0
    BorderColor #555555
    FontSize 10
}

left to right direction

' ═══ ACTORS (LEFT) ═══

:User\n(GUI): as U

' ═══ SYSTEM (CENTER) ═══

rectangle "Cross Guard System" {

    (Upload & Analyze Files) as UC1
    (Select Target Browsers) as UC2
    (View Results & Scores) as UC3
    (Export Report) as UC4
    (View History & Statistics) as UC5
    (Bookmark & Tag Analyses) as UC6
    (Get AI Fix Suggestions) as UC7
    (Get Polyfill Recommendations) as UC8
    (Manage Custom Rules) as UC9
    (Update Database) as UC10
    (Run CLI / CI Pipeline) as UC11
    (Quality Gate & CI Config) as UC12
}

' ═══ ACTORS (RIGHT) ═══

:Developer\n(CLI / CI): as D

' ═══ EXTERNAL SYSTEMS (BOTTOM) ═══

database "Can I Use\nDatabase" as CIU
database "SQLite" as SQL
cloud "LLM API" as LLM
cloud "NPM\nRegistry" as NPM

' ═══ USER --> USE CASES ═══

U -- UC1
U -- UC2
U -- UC3
U -- UC4
U -- UC5
U -- UC6
U -- UC7
U -- UC8
U -- UC9
U -- UC10

' ═══ DEVELOPER --> USE CASES ═══

D -- UC1
D -- UC4
D -- UC5
D -- UC10
D -- UC11
D -- UC12

' ═══ USE CASES --> EXTERNAL SYSTEMS ═══

UC1 ..> CIU : Check\nSupport
UC1 ..> SQL : Save\nResults
UC5 ..> SQL : Query
UC6 ..> SQL : Store
UC7 ..> LLM : Generate\nFixes
UC10 ..> NPM : Fetch\nLatest
UC10 ..> CIU : Update

@enduml
