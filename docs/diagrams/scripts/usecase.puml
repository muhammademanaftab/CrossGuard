@startuml

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Helvetica
skinparam defaultFontSize 12
skinparam dpi 200

skinparam actor {
    BackgroundColor white
    BorderColor #333333
    FontSize 13
}

skinparam usecase {
    BackgroundColor #EEEEEE
    BorderColor #444444
    FontSize 11
    Padding 10
}

skinparam rectangle {
    BackgroundColor #FAFAFA
    BorderColor #333333
    FontSize 16
    RoundCorner 15
    FontStyle bold
}

skinparam database {
    BackgroundColor #E0E0E0
    BorderColor #555555
    FontSize 11
}

skinparam cloud {
    BackgroundColor #E0E0E0
    BorderColor #555555
    FontSize 11
}

left to right direction

' ══════════════════════════════════════
'  ACTORS
' ══════════════════════════════════════

:User: as U
:Developer: as D

' ══════════════════════════════════════
'  SYSTEM
' ══════════════════════════════════════

rectangle " " {
    (Analyze Files for\nBrowser Compatibility) as UC1
    (View Results,\nScores & Issues) as UC2
    (Export Reports) as UC3
    (Browse History\n& Statistics) as UC4
    (AI & Polyfill\nSuggestions) as UC5
    (Configure Rules\n& Update Database) as UC6
    (CI/CD Pipeline\n& Quality Gates) as UC7
}

' ══════════════════════════════════════
'  EXTERNAL SYSTEMS
' ══════════════════════════════════════

database "SQLite" as SQL
database "Can I Use DB" as CIU
cloud "LLM API" as LLM
cloud "NPM Registry" as NPM

' ══════════════════════════════════════
'  USER (primary actor, left side)
' ══════════════════════════════════════

U -- UC1
U -- UC2
U -- UC3
U -- UC4
U -- UC5
U -- UC6

' ══════════════════════════════════════
'  DEVELOPER (secondary actor, right side)
' ══════════════════════════════════════

D -- UC1
D -- UC3
D -- UC6
D -- UC7

' ══════════════════════════════════════
'  EXTERNAL SYSTEM CONNECTIONS
' ══════════════════════════════════════

UC1 ..> CIU : Check\nSupport
UC1 ..> SQL : Save\nResults
UC4 ..> SQL : Query
UC5 ..> LLM : Generate\nFixes
UC6 ..> NPM : Fetch\nLatest
UC6 ..> CIU : Update

@enduml
